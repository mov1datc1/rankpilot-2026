generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum SubmissionStatus {
  DRAFT
  IN_REVIEW
  SUBMITTED
  ACCEPTED
  REJECTED
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  role             Role     @default(USER)
  stripeCustomerId String?
  subscriptionId   String?
  status           String   @default("ACTIVE")
  submissions      Submission[]
  aiLogs           AILog[]
}

model Submission {
  id                String           @id @default(uuid())
  userId            String
  targetDirectory   String
  guideRegion       String
  practiceArea      String
  currentBand       String
  deadline          DateTime?
  status            String           @default("Draft")
  completenessScore Int              @default(0)
  documentUrl       String?
  chambersData      Json?
  submittedAt       DateTime?
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matters           Matter[]
}

model Matter {
  id             String   @id @default(uuid())
  submissionId   String
  name           String
  client         String
  value          String
  leadPartner    String
  rawNotes       String?  @db.Text
  optimizedText  String?  @db.Text
  status         String   @default("Draft")
  threadId       String?
  isConfidential Boolean  @default(false)
  crossBorder    String?
  teamMembers    String?
  otherFirms     String?
  completionDate String?
  otherInfo      String?
  isNewClient    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  aiLogs         AILog[]
}

model AILog {
  id          String   @id @default(uuid())
  userId      String
  matterId    String?
  prompt      String   @db.Text
  response    String   @db.Text
  durationMs  Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matter      Matter?  @relation(fields: [matterId], references: [id], onDelete: SetNull)
}
