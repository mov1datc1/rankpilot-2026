generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum AccountType {
  INDIVIDUAL
  CORPORATE
}

enum SubmissionStatus {
  DRAFT
  IN_REVIEW
  SUBMITTED
  ACCEPTED
  REJECTED
}

model User {
  id               String      @id @default(uuid())
  email            String      @unique
  name             String?
  role             Role        @default(USER)
  accountType      AccountType @default(INDIVIDUAL)
  stripeCustomerId String?
  subscriptionId   String?
  status           String      @default("ACTIVE")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @default(now()) @updatedAt
  submissions      Submission[]
  aiLogs           AILog[]
  matters          Matter[]
  firms            Firm[]
}

// =====================================================
// SYSTEM CONFIG — Global platform settings (singleton)
// Stores GTM, GA4, Stripe, Resend configs
// =====================================================
model SystemConfig {
  id                     String   @id @default("global")
  gaMeasurementId        String?
  gtmContainerId         String?
  resendApiKey           String?
  resendFromEmail        String?
  stripeTestMode         Boolean  @default(true)
  maintenanceModeEnabled Boolean  @default(false)
  updatedAt              DateTime @updatedAt
}

// =====================================================
// EMAIL TEMPLATE — Dynamic email templates (SMTP)
// Types: WELCOME, DUNNING, REMINDER
// =====================================================
model EmailTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  subject   String
  htmlBody  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================
// FIRM MODEL — Normalized firm entity for Matter Library
// Enables autocomplete and structured firm management
// =====================================================
model Firm {
  id          String   @id @default(uuid())
  userId      String
  name        String
  country     String?
  city        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matters     Matter[]

  @@unique([userId, name])
}

model Submission {
  id                String           @id @default(uuid())
  userId            String
  targetDirectory   String
  guideRegion       String
  practiceArea      String
  currentBand       String
  deadline          DateTime?
  status            String           @default("Draft")
  completenessScore Int              @default(0)
  documentUrl       String?
  chambersData      Json?
  submittedAt       DateTime?
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matters           Matter[]
}

model Matter {
  id             String   @id @default(uuid())
  submissionId   String?
  userId         String
  firmId         String?
  name           String
  client         String
  value          String
  leadPartner    String
  rawNotes       String?  @db.Text
  optimizedText  String?  @db.Text
  status         String   @default("Draft")
  threadId       String?
  isConfidential Boolean  @default(false)
  crossBorder    String?
  teamMembers    String?
  otherFirms     String?
  completionDate String?
  otherInfo      String?
  isNewClient    Boolean  @default(false)

  // Library-specific fields
  source         String   @default("builder")   // "builder" | "assistant" | "manual"
  practiceArea   String?
  jurisdiction   String?
  description    String?  @db.Text
  tags           String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submission     Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm           Firm?       @relation(fields: [firmId], references: [id], onDelete: SetNull)
  aiLogs         AILog[]
  sources        MatterSource[]
}

// =====================================================
// MATTER SOURCE — Multiple files/documents per matter
// Supports emails, contracts, notes, PDFs per matter
// =====================================================
model MatterSource {
  id          String   @id @default(uuid())
  matterId    String
  fileName    String
  fileUrl     String
  fileType    String            // "pdf" | "docx" | "txt" | "email" | "notes"
  fileSize    Int       @default(0)
  rawText     String?   @db.Text   // Extracted text content from the file
  createdAt   DateTime  @default(now())

  matter      Matter    @relation(fields: [matterId], references: [id], onDelete: Cascade)
}

model AILog {
  id          String   @id @default(uuid())
  userId      String
  matterId    String?
  prompt      String   @db.Text
  response    String   @db.Text
  durationMs  Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matter      Matter?  @relation(fields: [matterId], references: [id], onDelete: SetNull)
}
